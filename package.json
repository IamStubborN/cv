{
  "name": "cv-builder",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "generate": "tsx src/cli.ts generate",
    "generate:all": "tsx src/cli.ts generate --all --resume-dir example/resumes",
    "generate:example": "tsx src/cli.ts generate --resume example/resumes/example.yaml",
    "generate:private": "tsx src/cli.ts generate --all --resume-dir private/resumes"
  },
  "dependencies": {
    "@fontsource/eb-garamond": "^5.2.7",
    "@react-pdf/renderer": "^4.5.1",
    "commander": "^15.0.0",
    "react": "^19.2.7",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "pdf-lib": "^1.17.1",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  }
}
